# Warehouse Store — copy to Warehouse_store/.env.local

# In production (FLASK_ENV=production) the API refuses to start while
# STORE_API_KEY / STORE_SECRET_KEY are left at these insecure defaults.
WAREHOUSE_URL=http://127.0.0.1:8000
STORE_API_KEY=store-dev-key
STORE_SECRET_KEY=change-me-store-secret
STORE_BACKEND_URL=http://127.0.0.1:5004
# Set to true when serving behind HTTPS so the session cookie is TLS-only.
STORE_COOKIE_SECURE=false
# STORE_API_HOST=127.0.0.1
# STORE_API_PORT=5004
# STORE_DATABASE=
# STORE_INSTANCE_PATH=
